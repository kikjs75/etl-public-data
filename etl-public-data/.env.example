# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=etl_public
POSTGRES_USER=etl_user
POSTGRES_PASSWORD=etl_password

# Public Data API Keys (data.go.kr)
AIR_QUALITY_API_KEY=your_air_quality_api_key
WEATHER_API_KEY=your_weather_api_key
SUBWAY_API_KEY=your_subway_api_key

# ETL Schedule (cron expression)
ETL_CRON_HOUR=*
ETL_CRON_MINUTE=0
QUALITY_REPORT_HOUR=1
QUALITY_REPORT_MINUTE=0

# Backend
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# Use mock data when API keys are not available
USE_MOCK_DATA=true
